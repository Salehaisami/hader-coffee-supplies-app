rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requesting user is an admin (via custom claim)
    function isAdmin() {
      return request.auth != null
        && request.auth.token.role == 'admin';
    }

    // Helper: check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: check if the user owns this document
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // ─── Products & Categories: public read, admin-only write ───
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Users: read/write own doc; admins can read/write all ───
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ─── Orders: customer creates/reads own; admin reads/writes all ───
    // Status field is admin-only writable
    match /orders/{orderId} {
      allow read: if isAdmin()
        || (isAuthenticated() && resource.data.customerId == request.auth.uid);

      allow create: if isAuthenticated()
        && request.resource.data.customerId == request.auth.uid
        && request.resource.data.status == 'pending';

      // Customers can only update to cancel their own pending orders
      allow update: if isAdmin()
        || (isAuthenticated()
            && resource.data.customerId == request.auth.uid
            && resource.data.status == 'pending'
            && request.resource.data.status == 'cancelled'
            && onlyFieldChanged('status'));

      allow delete: if false; // Orders are never deleted
    }

    // ─── Suppliers: admin-only (never exposed to the app) ───
    match /suppliers/{supplierId} {
      allow read, write: if isAdmin();
    }

    // Helper: verify only specific field changed
    function onlyFieldChanged(field) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([field, 'updatedAt']);
    }
  }
}
